# Non-secret local example. Copy to `.env` and fill real values outside git.
NODE_ENV=development
AINTEL_ENV=local
PORT=3000

MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB=inteligent_local

AINTEL_JWT_SECRET=replace-with-local-secret
AINTEL_WEB_INQUIRY_API_KEY=replace-with-local-browser-key
AINTEL_INTERNAL_API_KEY=replace-with-local-internal-key

AINTEL_SMTP_HOST=
AINTEL_SMTP_PORT=587
AINTEL_SMTP_SECURE=false
AINTEL_SMTP_USER=
AINTEL_SMTP_PASS=

# Staging must set:
# AINTEL_ENV=staging
# MONGO_DB=inteligent_staging
# AINTEL_EMAIL_TRAP_TO=staging-mailbox@example.test
# AINTEL_EMAIL_SUBJECT_PREFIX=[STAGING]
